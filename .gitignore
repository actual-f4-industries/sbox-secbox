# Build output
**/bin/
**/obj/

# IDE / user-local
.vs/
*.user
*.suo

# Auto-generated by s&box editor
# csproj / slnx are regenerated from .sbproj on every editor open — they
# carry machine-specific absolute paths and shouldn't be committed.
*.csproj
*.slnx
*.sln
**/Properties/
**/Properties/launchSettings.json
*.version

# Runtime artifacts — secbox stores the trust store at <projectRoot>/.secbox/
# (outside the library), but ignore here too in case dev/test runs land it
# inside the library folder.
.secbox/

# Compiled output / packaging
*.pdb
*.dll
*.xml
*launchSettings.json
